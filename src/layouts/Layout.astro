---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "txtui" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-(--color-bg) text-(--color-text) font-mono min-h-screen">
    <slot />
  </body>
</html>
