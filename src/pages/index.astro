---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import TagFilter from "../components/TagFilter.astro";
import UICard from "../components/UICard.astro";
import { extractPreview } from "../utils/extract-preview";

const uiCollection = await getCollection("uiCollection");

const allTags = [...new Set(uiCollection.flatMap((c) => c.data.tags))].sort();
---

<Layout
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "txtui",
    url: "https://txtui.dev",
    description:
      "Plain text UI patterns to explain UI structure to AI with fewer tokens",
  }}
>
  <section class="mb-12">
    <h1 class="text-3xl font-bold mb-2">
      Plain text UI patterns for AI agents
    </h1>
    <p class="text-text-muted text-lg mb-2">
      Copy-paste friendly, terminal-ready UI patterns rendered in plain text.
    </p>
    <p class="text-text-muted text-lg">
      Explain UI structure to AI more clearly with fewer tokens.
    </p>
  </section>

  {
    allTags.length > 0 && (
      <section class="mb-8">
        <TagFilter tags={allTags} />
      </section>
    )
  }

  <section
    id="ui-grid"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
  >
    {
      uiCollection.map((ui) => (
        <UICard
          title={ui.data.title}
          description={ui.data.description}
          slug={ui.id}
          preview={extractPreview(ui.body ?? "", ui.data.previewBlockId)}
          tags={ui.data.tags}
        />
      ))
    }
  </section>

  {
    uiCollection.length === 0 && (
      <p class="text-text-muted">No UI entries yet.</p>
    )
  }
</Layout>

<script>
  document.addEventListener("tagchange", ((e: CustomEvent) => {
    const selectedTags: string[] = e.detail.tags;
    const cards = document.querySelectorAll<HTMLElement>(
      "#ui-grid [data-tags]",
    );

    cards.forEach((card) => {
      const cardTags = (card.dataset.tags ?? "").split(",");
      if (
        selectedTags.length === 0 ||
        selectedTags.some((t) => cardTags.includes(t))
      ) {
        card.style.display = "";
      } else {
        card.style.display = "none";
      }
    });
  }) as EventListener);
</script>
