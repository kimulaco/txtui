---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const uiCollection = await getCollection("uiCollection");
  return uiCollection.map((ui) => ({
    params: { slug: ui.id },
    props: { ui },
  }));
}

const { ui } = Astro.props;
const { Content } = await render(ui);
---

<Layout
  title={`${ui.data.title} - txtui`}
  description={ui.data.description}
  jsonLd={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://txtui.dev/",
          },
          {
            "@type": "ListItem",
            position: 2,
            name: ui.data.title,
            item: `https://txtui.dev/ui/${ui.id}/`,
          },
        ],
      },
      {
        "@type": "WebPage",
        name: `${ui.data.title} - txtui`,
        description: ui.data.description,
        url: `https://txtui.dev/ui/${ui.id}/`,
      },
    ],
  }}
>
  <Breadcrumb uiName={ui.data.title} />

  <header class="mt-6 mb-8">
    <h1 class="text-3xl font-bold mb-2">{ui.data.title}</h1>
    <p class="text-text-muted text-lg mb-4">{ui.data.description}</p>
    <div class="flex flex-wrap gap-2">
      {
        ui.data.tags.map((tag: string) => (
          <span class="bg-surface text-text-muted border border-border rounded px-2 py-1 text-xs">
            {tag}
          </span>
        ))
      }
    </div>
  </header>

  <article>
    <Content />
  </article>
</Layout>

<style>
  article :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  article :global(pre) {
    background-color: var(--color-surface, #1e1e1e);
    border: 1px solid var(--color-border, #333);
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
    position: relative;
    font-size: 0.875rem;
    text-rendering: geometricPrecision;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: normal;
    font-variant-ligatures: none;
  }

  article :global(.code-editor-wrapper) {
    border: 1px solid var(--color-border, #333);
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--color-surface, #1e1e1e);
    margin-bottom: 1rem;
  }

  article :global(.code-editor-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background-color: rgb(30 30 30 / 92%);
    border-bottom: 1px solid var(--color-border, #333);
  }

  article :global(.code-editor-title) {
    font-size: 0.75rem;
    color: var(--color-text-muted, #a1a1aa);
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  article :global(.live-editor-pre) {
    margin: 0;
    border: 0;
    border-radius: 0;
    padding: 1rem;
  }

  article :global(pre code) {
    font-family: "Fira Code", monospace;
    font-size: inherit;
    white-space: pre;
  }

  article :global(.live-editor-content) {
    display: block;
    min-height: 4rem;
    outline: none;
    caret-color: var(--color-accent, #60a5fa);
  }

  article :global(.live-editor-content:focus) {
    box-shadow: 0 0 0 1px var(--color-accent, #60a5fa);
    border-radius: 0.25rem;
  }

  article :global(.code-tools) {
    background: transparent;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  article :global(.code-tool-btn) {
    line-height: 1;
    border: 1px solid var(--color-border, #3f3f46);
    border-radius: 0.375rem;
    padding: 0.375rem 0.5rem;
    background-color: rgb(38 38 38 / 90%);
    color: var(--color-text, #e5e7eb);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  article :global(.code-tool-btn:hover) {
    background-color: rgb(58 58 58 / 96%);
    border-color: var(--color-accent, #60a5fa);
  }

  article :global(.code-tool-btn:focus-visible) {
    outline: 2px solid var(--color-accent, #60a5fa);
    outline-offset: 1px;
  }

  article :global(p) {
    margin-bottom: 1rem;
    line-height: 1.625;
  }
</style>

<script>
  import { initLiveEditors } from "../../features/live-editor";

  initLiveEditors();
</script>
