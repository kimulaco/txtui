{
  "name": "txtui",
  "private": true,
  "type": "module",
  "version": "1.1.0",
  "scripts": {
    "prepare": "simple-git-hooks",
    "clean": "rm -rf node_modules",
    "dev": "PUBLIC_BUILD_ENV=development SENTRY_RELEASE=development@$npm_package_version PUBLIC_SENTRY_RELEASE=development@$npm_package_version astro dev --host",
    "build": "astro build",
    "build:dev": "PUBLIC_BUILD_ENV=development SENTRY_RELEASE=development@$npm_package_version PUBLIC_SENTRY_RELEASE=development@$npm_package_version astro build",
    "build:prod": "PUBLIC_BUILD_ENV=production SENTRY_RELEASE=production@$npm_package_version PUBLIC_SENTRY_RELEASE=production@$npm_package_version astro build",
    "fonts:build": "tsx scripts/fonts/ttf-to-woff2.ts",
    "start": "serve dist",
    "preview": "astro preview",
    "deploy:dev": "pnpm build:dev && wrangler deploy --env development",
    "deploy:prod": "pnpm build:prod && wrangler deploy --env production",
    "astro": "astro",
    "check:all": "pnpm fmt && pnpm lint:all && pnpm typecheck && pnpm test",
    "check:pre-commit": "pnpm fmt && pnpm lint:all && pnpm typecheck",
    "lint:all": "pnpm lint:eslint && pnpm lint:secret && pnpm lint:knip",
    "lint:fix": "pnpm lint:eslint:fix",
    "lint:eslint": "eslint .",
    "lint:knip": "knip",
    "lint:eslint:fix": "eslint . --fix",
    "lint:secret": "secretlint .",
    "fmt": "prettier . --check",
    "fmt:fix": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check:pre-commit"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.0",
    "@astrojs/sitemap": "3.7.1",
    "@sentry/astro": "10.43.0",
    "astro": "6.0.4"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "11.3.1",
    "@tailwindcss/vite": "4.2.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "10.0.2",
    "eslint-plugin-astro": "1.6.0",
    "knip": "5.85.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "secretlint": "11.3.1",
    "serve": "14.2.6",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "ttf2woff2": "8.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wrangler": "4.69.0"
  }
}
