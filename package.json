{
  "name": "txtui",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "clean": "rm -rf node_modules",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "allcheck": "pnpm fmt && pnpm lint:all && pnpm typecheck && pnpm test",
    "lint:ci": "pnpm lint:eslint && pnpm lint:knip",
    "lint:all": "pnpm lint:eslint && pnpm lint:secret && pnpm lint:knip",
    "lint:fix": "pnpm lint:eslint:fix",
    "lint:eslint": "eslint .",
    "lint:knip": "knip",
    "lint:eslint:fix": "eslint . --fix",
    "lint:secret": "secretlint '**/*'",
    "fmt": "prettier . --check",
    "fmt:fix": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "astro": "5.18.0"
  },
  "packageManager": "pnpm@10.30.0",
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "11.3.1",
    "@tailwindcss/vite": "4.2.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "eslint-plugin-astro": "1.6.0",
    "knip": "5.85.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "secretlint": "11.3.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
